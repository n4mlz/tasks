# SQLite database path
# Default: ./task-platform.db
TASK_PLATFORM_DB=./task-platform.db

# Internal planner provider
# Supported:
# - openai-compatible
# - openai
# - anthropic
TASK_PLATFORM_LLM_PROVIDER=openai-compatible

# Model name exposed by your provider or local compatible server
TASK_PLATFORM_LLM_MODEL=your-local-model

# Required for openai-compatible providers
TASK_PLATFORM_LLM_BASE_URL=http://127.0.0.1:1234/v1

# API key for the provider
# For local servers, a placeholder like "local" is fine if the server ignores it.
TASK_PLATFORM_LLM_API_KEY=local

# Set to true if your provider supports structured outputs natively.
TASK_PLATFORM_LLM_SUPPORTS_STRUCTURED_OUTPUTS=true
