# Task Platform environment example
#
# Local pnpm development:
# - copy to `.env`
# - keep TASK_PLATFORM_DB=./task-platform.db if you want the SQLite file in the repo root
#
# Docker Compose development:
# - copy to `.env`
# - set TASK_PLATFORM_DB=/data/task-platform.db to store SQLite in the named Docker volume
# - optionally set PORT to change the published web port

# Public web port
# Used by Docker Compose and by `next dev` when PORT is exported.
PORT=3000

# Host-side bind address for the web port published by Docker Compose
# Keep 127.0.0.1 for local-only access.
# Set 0.0.0.0 when you want other machines to reach the Web UI directly.
WEB_PUBLISH_HOST=0.0.0.0

# Optional comma-separated hostnames allowed to access Next.js dev resources
# from another machine. Example: ALLOWED_DEV_ORIGINS=wisteria,100.79.204.14
ALLOWED_DEV_ORIGINS=

# MCP HTTP port published by Docker Compose
MCP_PORT=3100

# Host-side bind address for the MCP HTTP port
# Keep 127.0.0.1 for local-only access.
# Set 0.0.0.0 when you intentionally want remote clients to connect directly.
MCP_PUBLISH_HOST=0.0.0.0

# MCP server listen host inside the process/container
TASK_PLATFORM_MCP_HOST=0.0.0.0

# MCP HTTP endpoint path
TASK_PLATFORM_MCP_PATH=/mcp

# Optional comma-separated hostnames allowed by MCP HTTP host-header validation.
# Useful when TASK_PLATFORM_MCP_HOST=0.0.0.0 on an internet-facing server.
# Example: TASK_PLATFORM_MCP_ALLOWED_HOSTS=mcp.example.com
TASK_PLATFORM_MCP_ALLOWED_HOSTS=

# SQLite database path
# Local default: ./task-platform.db
# Docker Compose recommended: /data/task-platform.db
TASK_PLATFORM_DB=./task-platform.db

# Internal planner provider
# Supported:
# - openai-compatible
# - openai
# - anthropic
TASK_PLATFORM_LLM_PROVIDER=openai-compatible

# Model name exposed by your provider or local compatible server
TASK_PLATFORM_LLM_MODEL=your-local-model

# Required for openai-compatible providers
TASK_PLATFORM_LLM_BASE_URL=http://127.0.0.1:1234/v1

# API key for the provider
# For local servers, a placeholder like "local" is fine if the server ignores it.
TASK_PLATFORM_LLM_API_KEY=local

# Set to true if your provider supports structured outputs natively.
TASK_PLATFORM_LLM_SUPPORTS_STRUCTURED_OUTPUTS=true

# Timeout for internal LLM scheduling requests in milliseconds.
TASK_PLATFORM_LLM_TIMEOUT_MS=20000
