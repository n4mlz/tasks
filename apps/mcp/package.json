{
  "name": "mcp",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@task-platform/application": "workspace:*",
    "@task-platform/contracts": "workspace:*",
    "@task-platform/infrastructure": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "tsx": "^4.21.0"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts --transport=http",
    "build": "tsc -p tsconfig.json",
    "start": "node --import tsx src/main.ts --transport=stdio",
    "start:http": "node --import tsx src/main.ts --transport=http",
    "test": "pnpm --dir ../.. exec vitest --run apps/mcp/tests"
  }
}
