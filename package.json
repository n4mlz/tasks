{
  "name": "task-platform",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest --run",
    "test:domain": "vitest --run packages/domain/tests",
    "lint": "tsc -b --pretty false",
    "dev:web": "pnpm --filter web dev",
    "dev:mcp": "pnpm --filter mcp dev"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
